# realvirtual WebViewer — Bunny CDN deploy credentials (scripts/bunny-deploy.mjs)
#
# These are the SAME values you enter in the Unity Editor under
#   WebViewer Tools > Publish (stored there as EditorPrefs).
# Keep BOTH places in sync: if you rotate a key, update Unity EditorPrefs AND
# this file / your CI secrets — otherwise the two deploy paths drift apart.
#
# Copy to `.env` (gitignored) and fill in real values, OR provide them as
# environment variables / CI secrets. NEVER commit real keys.

# --- Required ---------------------------------------------------------------
# Storage-zone password (used for upload / list / delete).
BUNNY_STORAGE_KEY=
# Storage-zone name.
BUNNY_STORAGE_ZONE=realvitual-web

# --- Required only for cache purge ------------------------------------------
# Account API key (cache purge). Without it (and the pull-zone id) purge is skipped.
BUNNY_ACCOUNT_KEY=
# Pull-zone id (cache purge).
BUNNY_PULL_ZONE_ID=

# --- Optional ---------------------------------------------------------------
# Region hostname. A dashboard label suffix like
#   "storage.bunnycdn.com (Falkenstein DE)"
# is accepted — only the first token is used. Default: storage.bunnycdn.com
BUNNY_REGION=storage.bunnycdn.com
# Public remote path prefix (e.g. "demo" or "dev"). Empty = storage-zone root.
BUNNY_REMOTE_PATH=
# Private projects root directory (for --private). Can also be passed via --projects-dir.
BUNNY_PRIVATE_PROJECTS_DIR=

# --- Analytics --------------------------------------------------------------
# GA4 Measurement ID injected into the DEPLOYED settings.json only.
# The committed settings.json ships with an empty id so public AGPL forks do
# not send traffic into our property. Leave empty for no analytics.
GA_MEASUREMENT_ID=
