{
  "name": "realvirtual-webviewer-mcp-bridge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local Node/TS MCP bridge: stdio MCP server <-> realvirtual WEB browser over WebSocket (:18714).",
  "license": "AGPL-3.0-only",
  "main": "dist/index.js",
  "bin": {
    "realvirtual-webviewer-mcp": "dist/index.js"
  },
  "scripts": {
