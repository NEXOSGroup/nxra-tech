{
  "name": "Sketch",
  "schemaVersion": 1,
  "settings": {
    "renderMode": "toon",
    "modeSettings": {
      "simple": {
        "lightIntensity": 1,
        "toneMapping": "none",
        "toneMappingExposure": 1,
        "ambientColor": "#ffffff",
        "ambientIntensity": 1,
        "dirLightEnabled": false,
        "dirLightColor": "#ffffff",
        "dirLightIntensity": 1.5,
        "shadowEnabled": false,
        "shadowIntensity": 0.5,
        "shadowQuality": "medium"
      },
      "default": {
        "lightIntensity": 0.5,
        "toneMapping": "none",
        "toneMappingExposure": 1,
        "ambientColor": "#404040",
        "ambientIntensity": 0.75,
        "dirLightEnabled": true,
        "dirLightColor": "#ffffff",
        "dirLightIntensity": 1.5,
        "shadowEnabled": true,
        "shadowIntensity": 1,
        "shadowQuality": "medium"
      },
      "toon": {
        "lightIntensity": 1,
        "toneMapping": "none",
        "toneMappingExposure": 1,
        "ambientColor": "#ffffff",
        "ambientIntensity": 0.45,
        "dirLightEnabled": true,
        "dirLightColor": "#ffffff",
        "dirLightIntensity": 2,
        "shadowEnabled": false,
        "shadowIntensity": 0.5,
        "shadowQuality": "medium"
      }
    },
    "projection": "perspective",
    "fov": 60,
    "antialias": true,
    "shadowMapSize": 2048,
    "shadowRadius": 2,
    "maxDpr": 2,
    "aoMode": "gtao",
    "ssaoIntensity": 1,
    "ssaoRadius": 0.1,
    "bloomEnabled": true,
    "bloomIntensity": 0.25,
    "bloomThreshold": 0.8,
    "bloomRadius": 0.4,
    "toonBands": 3,
    "toonMetallic": 1,
    "toonMetallicColor": "#babfca",
    "toonAlbedoMinBrightness": 0.1,
    "toonAlbedoMaxBrightness": 1,
    "toonAlbedoSaturation": 0.4,
    "toonOutlineAmount": 0.4,
    "toonOutlineThickness": 1,
    "toonOutlineThreshold": 0.2,
    "toonOutlineDistance": 100,
    "toonOutlineSupersample": true,
    "toonOutlineColor": "#000000",
    "toonCoolShadows": true,
    "groundEnabled": true,
    "groundBrightness": 1,
    "groundColor": "#ffffff",
    "backgroundBrightness": 1,
    "checkerContrast": 0.5,
    "reflectionEnabled": false,
    "reflectionStrength": 0.8,
    "reflectionBlur": 1
  }
}